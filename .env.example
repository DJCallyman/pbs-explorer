# PBS Explorer Environment Configuration
# Copy this file to .env and fill in your values

# Required: PBS API Subscription Key
# Get your key from: https://data-api.health.gov.au/pbs/api/v3
PBS_EXPLORER_PBS_SUBSCRIPTION_KEY=your_subscription_key_here

# Optional: Admin API Key
# Reserved for deployments where you later choose to lock down admin endpoints.
# Generate a secure random key, e.g.: python -c "import secrets; print(secrets.token_urlsafe(32))"
# PBS_EXPLORER_ADMIN_API_KEY=your_admin_api_key_here

# Recommended for any remote deployment:
# bootstrap browser login for the whole app
# you can later retire this bootstrap login if you create managed users/admins in the Admin page
# PBS_EXPLORER_WEB_USERNAME=your_username
# PBS_EXPLORER_WEB_PASSWORD=generate_a_strong_random_password_here

# Optional: Database Configuration (SQLite is default)
# PBS_EXPLORER_DB_TYPE=sqlite
# PBS_EXPLORER_DB_PATH=./pbs_data.db

# Optional: Server Configuration
# PBS_EXPLORER_SERVER_HOST=127.0.0.1
# PBS_EXPLORER_SERVER_PORT=8000
# PBS_EXPLORER_SERVER_TRUSTED_HOSTS=127.0.0.1,localhost,::1
# PBS_EXPLORER_SERVER_ENABLE_DOCS=false
# PBS_EXPLORER_SERVER_ENABLE_PSD=true

# Optional: Logging
# PBS_EXPLORER_LOG_LEVEL=INFO
# PBS_EXPLORER_LOG_JSON=false  # Set to true for structured JSON log output
